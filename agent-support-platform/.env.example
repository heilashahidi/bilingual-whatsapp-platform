# Database
DATABASE_URL="postgresql://asp_user:asp_dev_password@localhost:5432/agent_support"

# Redis
REDIS_URL="redis://localhost:6379"

# Twilio (WhatsApp Sandbox)
# Set USE_REAL_WHATSAPP=true once you have Twilio credentials; otherwise the
# stub logs outbound sends without actually contacting Twilio.
USE_REAL_WHATSAPP=false
TWILIO_ACCOUNT_SID="your_account_sid"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_NUMBER="+14155238886"  # Twilio sandbox number

# Public URL that Twilio hits for inbound webhooks. Must match the URL
# configured in the Twilio Sandbox so signature validation passes.
# In dev: your ngrok https URL. In prod: your real domain.
WEBHOOK_BASE_URL="https://your-ngrok-subdomain.ngrok-free.dev"

# Country fallback for phone numbers whose prefix isn't HT/DR/DRC
# (e.g., a US test number on the Twilio sandbox). The pipeline requires
# a valid Country enum value; this prevents a crash on auto-registration.
# Valid values: HT, DO, CD. Defaults to HT if unset.
TEST_AGENT_COUNTRY="HT"

# Google Cloud Translation
# Stub mode is the default. Flip to true once you have a Google Cloud
# service account JSON for the Cloud Translation API.
USE_REAL_TRANSLATION=false
GOOGLE_CLOUD_PROJECT_ID="your_project_id"
GOOGLE_APPLICATION_CREDENTIALS="./google-credentials.json"

# LLM Classification (Claude Haiku)
# If ANTHROPIC_API_KEY is unset, the code logs a warning and falls back
# to the keyword stub even when USE_REAL_CLASSIFICATION=true.
USE_REAL_CLASSIFICATION=false
ANTHROPIC_API_KEY="your_anthropic_key"

# Server
PORT=3001
NODE_ENV="development"

# Dashboard
NEXT_PUBLIC_API_URL="http://localhost:3001"
